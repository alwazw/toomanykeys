generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  sessions           Session[]
  universalMasterKey UniversalMasterKey?

  // Community participation
  isDonatingToPool   Boolean             @default(false)
}

model UniversalMasterKey {
  id           String              @id @default(cuid())
  userId       String              @unique
  name         String              @default("Universal Master Key")
  token        String              @unique
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  providerKeys ProviderMasterKey[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderMasterKey {
  id                   String             @id @default(cuid())
  universalMasterKeyId String
  provider             String
  name                 String
  isActive             Boolean            @default(true)
  priority             Int                @default(1)

  // Dashboard Mirror Stats (Aggregated)
  rawSpeedLimit        String?            // e.g. "10 RPM"
  rawDistanceCap       String?            // e.g. "1M tokens/day"

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  apiKeys              ApiKey[]
  universalMasterKey   UniversalMasterKey @relation(fields: [universalMasterKeyId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id                  String            @id @default(cuid())
  providerMasterKeyId String
  providerMasterKey   ProviderMasterKey @relation(fields: [providerMasterKeyId], references: [id], onDelete: Cascade)

  // Encrypted Key Storage
  encryptedKey        String            // AES-256-GCM encrypted
  keyIv               String            // Initialization Vector
  keyAuthTag          String            // Auth Tag for GCM

  name                String?
  isActive            Boolean           @default(true)
  isPoolDonation      Boolean           @default(false) // Toggle for Community Pool

  // Quota tracking
  totalQuota          Float?
  usedQuota           Float             @default(0)
  lastUsedAt          DateTime?
  rateLimitedUntil    DateTime?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
